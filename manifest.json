{
  "manifest_version": 3,
  "name": "AI Live Captions",
  "version": "3.0",
  "description": "Real-time AI captions for YouTube and videos using OpenAI Whisper",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabCapture",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*",
    "ws://localhost:8001/*",
    "http://localhost:8001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
  ],
  "icons": {
    "48": "icon.png"
  }
}